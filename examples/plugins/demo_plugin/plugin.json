{
  "id": "demo-plugin",
  "name": "Demo Plugin",
  "version": "0.1.0",
  "apiVersion": "1",
  "runtime": "python",
  "entry": "main.py",
  "description": "Demonstrates plugin introduction panels, persisted settings, numeric options, and sample-file selection.",
  "enabledByDefault": true,
  "settingsPanel": {
    "summary": "这是一个演示插件，用来展示 PM Center 插件设置框架的完整能力。你可以在这里填写数字、开关、下拉项和文件选择参数，保存后插件运行时会直接拿到这些值。",
    "sections": [
      {
        "title": "适合演示什么",
        "content": "1. 亮度倍数这样的数字参数\n2. 是否翻转这样的布尔开关\n3. 输出模式这样的下拉项\n4. 样本图片这样的文件选择参数",
        "tone": "info"
      },
      {
        "title": "文件参数怎么存",
        "content": "这个示例把样本图片复制到插件自己的设置目录里，所以插件运行时不依赖原始文件位置。",
        "tone": "success"
      }
    ],
    "settings": {
      "title": "处理参数",
      "description": "这些值会保存到插件设置里，并在执行动作时通过 request.settingsValues 注入给 Python。",
      "storage": "pluginDir",
      "fields": [
        {
          "key": "brightnessFactor",
          "label": "亮度倍数",
          "type": "number",
          "defaultValue": 1.3,
          "min": 0.1,
          "max": 4.0,
          "step": 0.05,
          "unit": "x",
          "description": "例如 1.3 表示提亮 30%。"
        },
        {
          "key": "enableMirror",
          "label": "同时水平翻转",
          "type": "boolean",
          "defaultValue": true,
          "description": "关闭后只执行提亮，不做镜像。"
        },
        {
          "key": "outputSuffix",
          "label": "输出后缀",
          "type": "text",
          "defaultValue": "_demo_adjusted",
          "placeholder": "例如 _demo_adjusted",
          "description": "处理后的文件会使用这个后缀生成新文件名。"
        },
        {
          "key": "qualityMode",
          "label": "输出模式",
          "type": "select",
          "defaultValue": "balanced",
          "description": "用来演示下拉参数的读取。",
          "options": [
            {
              "label": "平衡",
              "value": "balanced"
            },
            {
              "label": "更亮",
              "value": "bright"
            },
            {
              "label": "仅提亮",
              "value": "light-only"
            }
          ]
        },
        {
          "key": "sampleImage",
          "label": "样本图片",
          "type": "file",
          "description": "选择一张样本图片作为参考。保存时会复制到插件设置目录。",
          "accept": [
            "png",
            "jpg",
            "jpeg",
            "webp",
            "bmp"
          ],
          "fileStoreMode": "copy",
          "picker": "file"
        }
      ]
    }
  },
  "contributes": {
    "commands": [
      {
        "id": "show-demo-settings",
        "title": "查看 Demo 插件配置",
        "description": "显示当前保存的演示插件设置。"
      },
      {
        "id": "process-demo-images",
        "title": "按 Demo 设置处理图片",
        "description": "对选中的图片执行镜像和提亮，并使用设置面板里的参数。"
      }
    ],
    "toolbarActions": [
      {
        "command": "show-demo-settings",
        "when": {
          "projectOpen": true
        }
      }
    ],
    "fileContextActions": [
      {
        "command": "process-demo-images",
        "when": {
          "selectionCount": "any",
          "targetKind": "file",
          "extensions": [
            "png",
            "jpg",
            "jpeg",
            "webp",
            "bmp",
            "tif",
            "tiff"
          ]
        },
        "menu": {
          "placement": "inline"
        }
      }
    ]
  },
  "permissions": []
}
