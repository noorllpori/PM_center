{
  "id": "hello-plugin",
  "name": "Hello Plugin",
  "version": "0.1.0",
  "apiVersion": "1",
  "runtime": "python",
  "entry": "main.py",
  "description": "A sample PM Center plugin for toolbar and file-context actions.",
  "enabledByDefault": true,
  "contributes": {
    "commands": [
      {
        "id": "hello",
        "title": "Hello Plugin",
        "description": "Show a toast and print a small result payload."
      }
    ],
    "toolbarActions": [
      {
        "command": "hello",
        "when": {
          "projectOpen": true
        }
      }
    ],
    "fileContextActions": [
      {
        "command": "hello",
        "when": {
          "selectionCount": "single",
          "targetKind": "file"
        }
      }
    ]
  },
  "permissions": []
}
